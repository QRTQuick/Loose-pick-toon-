# ── Vercel API ────────────────────────────────────────────────────────────────
LOOSEPICK_API_URL=https://loose-pick-toon.vercel.app

# ── Spotify App (set these in Vercel dashboard too) ───────────────────────────
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=https://loose-pick-toon.vercel.app/api/callback

# ── Filled in after visiting /api/login ───────────────────────────────────────
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
